# ============================================================
# 프로덕션 환경 변수 예시 파일
# 실제 사용 시 .env 파일로 복사 후 모든 값 교체
# cp .env.production.example .env
#
# 주의: 이 파일을 절대 git에 실제 값과 함께 커밋하지 마세요
# ============================================================

# ─── Redis 설정 ───────────────────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME_STRONG_REDIS_PASSWORD@redis:6379/0
CELERY_BROKER_URL=redis://:CHANGE_ME_STRONG_REDIS_PASSWORD@redis:6379/0
CELERY_RESULT_BACKEND=redis://:CHANGE_ME_STRONG_REDIS_PASSWORD@redis:6379/1
# 강력한 비밀번호 필수: openssl rand -base64 32
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# ─── 파일 저장소 ──────────────────────────────────────────────────────────────
TEMP_DIR=/app/storage/temp
RESULTS_DIR=/app/storage/results

# ─── STT 모델 설정 ────────────────────────────────────────────────────────────
WHISPER_MODEL=mlx-community/whisper-large-v3-turbo
WHISPER_LANGUAGE=ko

# ─── 처리 제한 ────────────────────────────────────────────────────────────────
MAX_CONCURRENT_JOBS=3
MAX_FILE_SIZE_MB=500
MAX_DURATION_HOURS=4
CHUNK_DURATION_MINUTES=30
CHUNK_OVERLAP_SECONDS=5

# ─── Redis 캐시 TTL (초) ──────────────────────────────────────────────────────
CACHE_TTL_SECONDS=86400

# ─── 메모리 경고 임계값 (MB) ──────────────────────────────────────────────────
MEMORY_WARNING_THRESHOLD_MB=19660

# ─── HuggingFace 설정 (화자 분리용) ──────────────────────────────────────────
# HuggingFace 계정에서 발급: https://huggingface.co/settings/tokens
# pyannote/speaker-diarization-3.1 및 pyannote/embedding gated model 접근 필요.
# 토큰 존재만으로 충분하지 않음. docs/speaker-voiceprint-runbook.md 검증 절차 확인.
HUGGINGFACE_TOKEN=hf_CHANGE_ME_YOUR_HUGGINGFACE_TOKEN

# ─── 화자 분리 설정 ───────────────────────────────────────────────────────────
MAX_CONCURRENT_DIARIZATIONS=2
DIARIZATION_MODEL=pyannote/speaker-diarization-3.1
DIARIZATION_RESULT_TTL=86400
SPEAKER_EMBEDDING_MODEL=pyannote/embedding
SPEAKER_VOICEPRINT_SIMILARITY_THRESHOLD=0.82
SPEAKER_VOICEPRINT_MAX_SECONDS_PER_SPEAKER=30
SPEAKER_VOICEPRINT_MIN_MATCH_SECONDS=8
SPEAKER_VOICEPRINT_MIN_ENROLL_SECONDS=8

# ─── 회의록 생성 설정 ─────────────────────────────────────────────────────────
MAX_CONCURRENT_MINUTES=3
MINUTES_RESULT_TTL=86400

# ─── AI 요약 설정 (Z.AI Coding Plan API) ──────────────────────────────────
LLM_PROVIDER=zai
ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4
ZAI_API_KEY=CHANGE_ME_YOUR_ZAI_API_KEY
ANTHROPIC_API_KEY=
MAX_CONCURRENT_SUMMARIES=2
SUMMARY_RESULT_TTL=86400
SUMMARY_MAX_TOKENS=2000
SUMMARY_MODEL=glm-5.2

# ─── 로깅 (프로덕션은 WARNING 권장) ──────────────────────────────────────────
LOG_LEVEL=WARNING

# ─── 서버 설정 ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ─── 보안 설정 (프로덕션 필수) ────────────────────────────────────────────────
# 강력한 API Key 생성: openssl rand -hex 32 (최소 2개 권장)
API_KEYS=CHANGE_ME_API_KEY_1,CHANGE_ME_API_KEY_2
# Google OAuth Web client ID. 여러 플랫폼 audience를 허용해야 하면 쉼표로 구분.
# Comma-separated Web/iOS/Android/macOS OAuth client IDs accepted by backend.
GOOGLE_CLIENT_ID=CHANGE_ME_GOOGLE_WEB_CLIENT_ID,CHANGE_ME_GOOGLE_IOS_CLIENT_ID,CHANGE_ME_GOOGLE_ANDROID_CLIENT_ID,CHANGE_ME_GOOGLE_MACOS_CLIENT_ID
# 프로덕션 Rate Limit 조정 (서비스 규모에 맞게)
RATE_LIMIT_PER_MINUTE=30
# 허용 HTTP 메서드 (필요 최소한으로 제한)
CORS_ALLOW_METHODS=GET,POST,DELETE
# 허용 Origin 목록 (실제 프론트엔드 도메인으로 교체, 와일드카드 금지)
CORS_ALLOW_ORIGINS=https://your-app.example.com

# ─── 데이터베이스 설정 ────────────────────────────────────────────────────────
POSTGRES_DB=voicenote
POSTGRES_USER=voicenote
# 강력한 비밀번호 필수: openssl rand -base64 24
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DATABASE_URL=postgresql://voicenote:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/voicenote

# ─── 모니터링 설정 ────────────────────────────────────────────────────────────
METRICS_ENABLED=true
# Sentry DSN (에러 추적, Sentry 프로젝트에서 발급)
SENTRY_DSN=https://CHANGE_ME@sentry.io/CHANGE_ME_PROJECT_ID
# 환경 이름
ENVIRONMENT=production
