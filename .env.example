# ============================================================
# 환경 변수 예시 파일 - 개발 기본값 포함
# 실제 사용 시 .env 파일로 복사 후 값 수정
# cp .env.example .env
# ============================================================

# ─── Redis 설정 ───────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
# 프로덕션에서 반드시 설정 (docker-compose.prod.yml 사용 시 필수)
REDIS_PASSWORD=

# ─── 파일 저장소 ──────────────────────────────────────────────────────────────
TEMP_DIR=./storage/temp
RESULTS_DIR=./storage/results

# ─── STT 모델 설정 ────────────────────────────────────────────────────────────
WHISPER_MODEL=mlx-community/whisper-large-v3-turbo
WHISPER_LANGUAGE=ko

# ─── 처리 제한 ────────────────────────────────────────────────────────────────
MAX_CONCURRENT_JOBS=3
MAX_FILE_SIZE_MB=500
MAX_DURATION_HOURS=4
CHUNK_DURATION_MINUTES=30
CHUNK_OVERLAP_SECONDS=5

# ─── Redis 캐시 TTL (초) ──────────────────────────────────────────────────────
CACHE_TTL_SECONDS=86400

# ─── 메모리 경고 임계값 (MB) - 24GB의 80% ────────────────────────────────────
MEMORY_WARNING_THRESHOLD_MB=19660

# ─── HuggingFace 설정 (화자 분리용) ──────────────────────────────────────────
# pyannote/speaker-diarization-3.1 모델 사용 시 필요
HUGGINGFACE_TOKEN=

# ─── 화자 분리 설정 ───────────────────────────────────────────────────────────
MAX_CONCURRENT_DIARIZATIONS=2
DIARIZATION_MODEL=pyannote/speaker-diarization-3.1
DIARIZATION_RESULT_TTL=86400

# ─── 회의록 생성 설정 ─────────────────────────────────────────────────────────
MAX_CONCURRENT_MINUTES=3
MINUTES_RESULT_TTL=86400

# ─── 자동 키워드 추천 설정 ───────────────────────────────────────────────────
KEYWORD_MAX_KEYWORDS=20
KEYWORD_MIN_SCORE=0.05
KEYWORD_MIN_TERM_LENGTH=2
KEYWORD_TFIDF_WEIGHT=0.6
KEYWORD_TEXTRANK_WEIGHT=0.4
KEYWORD_TEXTRANK_WINDOW=4
KEYWORD_CLUSTER_SIMILARITY_THRESHOLD=0.34
KEYWORD_HISTORY_LIMIT=20
KEYWORD_RESULT_TTL=604800
KEYWORD_MAX_TEXT_CHARS=100000

# ─── AI 요약 설정 (OpenAI API) ────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MAX_CONCURRENT_SUMMARIES=2
SUMMARY_RESULT_TTL=86400
SUMMARY_MAX_TOKENS=2000
SUMMARY_MODEL=gpt-4o-mini

# ─── 로깅 ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── 서버 설정 ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ─── 보안 설정 (REQ-SEC-001) ──────────────────────────────────────────────────
# API Key 목록 (쉼표 구분, 비어있으면 개발 모드 - 인증 비활성화)
API_KEYS=
# JWT 서명 시크릿. 프로덕션에서는 32자 이상의 랜덤 문자열을 반드시 설정한다.
JWT_SECRET=
# 분당 요청 제한 (REQ-SEC-007)
RATE_LIMIT_PER_MINUTE=60
# 허용 HTTP 메서드 (REQ-SEC-009)
CORS_ALLOW_METHODS=GET,POST,DELETE
# 허용 Origin 목록 (REQ-SEC-010, 쉼표 구분)
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173
# 프로덕션 CORS 예시: 실제 서비스 도메인으로 교체하고 와일드카드(*)는 사용하지 마세요.
# CORS_ALLOW_ORIGINS=https://app.example.com,https://admin.example.com
# CORS_ALLOW_METHODS=GET,POST,PATCH,DELETE

# ─── 데이터베이스 설정 (프로덕션 사용) ────────────────────────────────────────
POSTGRES_DB=voicenote
POSTGRES_USER=voicenote
POSTGRES_PASSWORD=
# docker-compose.prod.yml은 내부 Postgres로 DATABASE_URL을 강제 생성한다.
# 로컬/수동 실행 시에는 async SQLAlchemy URL을 사용한다.
DATABASE_URL=postgresql+asyncpg://voicenote:password@localhost:5432/voicenote

# ─── 모니터링 설정 ────────────────────────────────────────────────────────────
# Prometheus 메트릭 활성화 여부
METRICS_ENABLED=true
# Sentry DSN (에러 추적, 비어있으면 비활성화)
SENTRY_DSN=
# 환경 이름 (개발/스테이징/프로덕션 구분)
ENVIRONMENT=development
