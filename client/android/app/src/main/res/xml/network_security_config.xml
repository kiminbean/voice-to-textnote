<?xml version="1.0" encoding="utf-8"?>
<!-- SPEC-SEC-002: Release/Profile network security baseline.
     Cleartext HTTP is denied by default. Debug-only localhost/Tailscale
     exceptions live in src/debug/res/xml/network_security_config.xml. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
